# ═══════════════════════════════════════════════════════════════════════════
#  Yuno — environment configuration
#
#  1. Copy this file to .env :   cp .env.example .env
#  2. Fill in at least ONE LLM provider key for `live` mode (instructions on
#     each line below). Anything you leave blank simply degrades gracefully.
#  3. Boot:                       make up && make seed
#
#  Everything below is optional — Yuno boots in deterministic `stub` mode
#  (no keys, no network) so the flow demos even with a fresh empty .env.
# ═══════════════════════════════════════════════════════════════════════════

# ── Infrastructure (do not edit — used by docker-compose) ───────────────────
DATABASE_URL=postgresql+asyncpg://yuno:yuno@postgres:5432/yuno
REDIS_URL=redis://redis:6379/0
APP_ENV=dev

# ── Host ports ───────────────────────────────────────────────────────────────
# `make up` (scripts/dev-up.sh) auto-selects free host ports, so leave these
# commented unless you want to pin specific ones.
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# PUBLIC_API_URL=http://localhost:8000   # browser → backend; must match BACKEND_PORT

# ═══ LLM PROVIDERS  ════════════════════════════════════════════════════════
# Fill at least ONE for `LLM_MODE=live`. Yuno's ModelRouter routes by an
# agent's task_type and falls back across whatever providers are keyed:
#   coding       → Anthropic Claude
#   normal       → OpenAI GPT
#   conversation → Google Gemini
# Missing a provider? Routing skips it gracefully. Missing ALL? Drops to stub.
# ───────────────────────────────────────────────────────────────────────────

# Anthropic Claude API key (claude-opus-4, claude-sonnet-4, claude-haiku-4)
# Get one at:   https://console.anthropic.com/settings/keys
# Pricing:      ~$3 / 1M input, $15 / 1M output for Sonnet 4.5
# Format:       sk-ant-api...
ANTHROPIC_API_KEY=

# OpenAI API key (gpt-4o, gpt-4o-mini, tts-1, text-embedding-3-small)
# Get one at:   https://platform.openai.com/api-keys
# Used for:     normal-task agents (Jarvis is gpt-4o-mini), TTS narration,
#               extremis long-term memory embeddings.
# Format:       sk-...
OPENAI_API_KEY=

# Google Gemini API key (gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash)
# Get one at:   https://aistudio.google.com/app/apikey   (free tier exists)
# Format:       AIzaSy...
GEMINI_API_KEY=

# Optional: AWS Bedrock region for Claude-on-Bedrock (not used by default)
AWS_REGION=

# ── Harness mode ────────────────────────────────────────────────────────────
# stub    deterministic canned replies, no keys, no network — best for tests
# live    real provider calls via ModelRouter (recommended for the demo)
# record  same as live, plus RecordingInterceptor writes calls to DB
# replay  ReplayProvider serves from a recording — free, offline, reproducible
LLM_MODE=stub
LLM_PROVIDER_DEFAULT=openai
LLM_RECORDING_NAME=
LLM_SCRIPT_PATH=

# ═══ TOOLS  ════════════════════════════════════════════════════════════════

# Tavily API key — powers the `web_search` tool used by Cited Research,
# Remy the Researcher, and Jarvis's research delegations.
# Get one at:   https://app.tavily.com/  (free tier: 1000 searches/month)
# Without it:   web_search returns a stub result with a helpful "no key" note.
# Format:       tvly-...
TAVILY_API_KEY=

# ═══ TELEGRAM CHANNEL  ══════════════════════════════════════════════════════

# Telegram bot token — connects Jarvis (or any agent) to a real Telegram chat.
# How to get one in 90 seconds:
#   1. Open Telegram, search for @BotFather
#   2. Send /newbot, follow the prompts
#   3. @BotFather replies with a token like 1234567890:ABCdef-...
#   4. Paste it here, then in the UI: Channels → Add channel → Bind to Jarvis
#   5. Send your bot any message and watch it reply
# Without it:   the Telegram features are disabled, everything else works.
TELEGRAM_BOT_TOKEN=

# Transport: 'polling' = no public URL needed (works on any laptop).
#            'webhook' = production mode, needs PUBLIC_BASE_URL via cloudflared/ngrok.
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_SECRET=
PUBLIC_BASE_URL=

# ═══ LONG-TERM MEMORY (extremis)  ═══════════════════════════════════════════
# Extremis runs EMBEDDED in the backend/worker — no separate service to start.
# It backs to the same Postgres+pgvector you already have, and uses OpenAI
# embeddings (reuses OPENAI_API_KEY above). The `external` memory strategy
# degrades to in-run buffer memory if these are unset.
EXTREMIS_STORE=postgres
EXTREMIS_POSTGRES_URL=postgresql://yuno:yuno@postgres:5432/yuno
EXTREMIS_EMBEDDER=text-embedding-3-small
EXTREMIS_EMBEDDING_DIM=1536

# ═══ MCP SERVERS  ═══════════════════════════════════════════════════════════
# Built-ins (always available, no config):
#   - demo (stdio)           — calculate, current_time, word_stats
#   - playwright (sse)       — full real browser, in a docker container
# Add ANY other MCP server without code changes:
# PLAYWRIGHT_MCP_URL=http://playwright-mcp:8931/sse
# PLAYWRIGHT_MCP_TRANSPORT=sse
# MCP_SERVERS_JSON={"github":{"transport":"http","url":"http://my-mcp:9000/mcp"}}
