# ── Infrastructure ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yuno:yuno@postgres:5432/yuno
REDIS_URL=redis://redis:6379/0
APP_ENV=dev

# ── Host ports ───────────────────────────────────────────────────────────────
# Managed automatically by scripts/dev-up.sh (`make up`): it scans for free ports
# and writes the chosen values here. Set them manually only to pin specific ports.
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# PUBLIC_API_URL=http://localhost:8000   # browser -> backend; must match BACKEND_PORT

# ── LLM providers (fill at least one to run in 'live' mode) ──────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AWS_REGION=

# ── Harness mode: stub | live | record | replay ─────────────────────────────
# 'stub' needs no keys (deterministic). 'live' uses the ModelRouter, which routes
# by an agent's task_type (coding->Anthropic, normal->OpenAI, conversation->Gemini)
# and falls back across providers that have a key — degrading to stub if none do.
LLM_MODE=stub
LLM_PROVIDER_DEFAULT=openai
LLM_RECORDING_NAME=
LLM_SCRIPT_PATH=

# ── Tools ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Telegram channel ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# 'polling' for friction-free dev; switch to 'webhook' for the snappy demo.
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_SECRET=
# Public tunnel URL for webhook registration (e.g. cloudflared), webhook mode only.
PUBLIC_BASE_URL=

# ── Memory (extremis) ────────────────────────────────────────────────────────
# Ships in docker-compose; the ExternalMemoryStrategy degrades gracefully if unset.
EXTREMIS_URL=http://extremis:8080
EXTREMIS_STORE=
